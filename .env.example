# =============================================================================
# AgentForge — Configuration
# Copier ce fichier en .env et renseigner les valeurs
# cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider
# Valeurs possibles : anthropic | openai | ollama
# -----------------------------------------------------------------------------
LLM_PROVIDER=anthropic

# Clé Anthropic (utilisée si LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Clé OpenAI (utilisée si LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-openai-key-here

# Modèle à utiliser
# Anthropic : claude-opus-4-6 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
# OpenAI    : gpt-4o | gpt-4-turbo
# Ollama    : llama3 | mistral | codellama (selon ce que vous avez pull)
LLM_MODEL=claude-sonnet-4-6

# URL base Ollama (utilisée si LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# -----------------------------------------------------------------------------
# Forgejo — Forge Git self-hosted
# -----------------------------------------------------------------------------
# Domaine ou IP (sans http://, sans slash final)
# Exemples : 192.168.1.100 | myvps.example.com
FORGEJO_DOMAIN=localhost

# Port HTTP Forgejo (défaut 3000)
FORGEJO_PORT=3000

# Compte administrateur Forgejo (créé lors du premier démarrage)
FORGEJO_ADMIN_USER=admin
FORGEJO_ADMIN_PASS=changeme_strong_password_here
FORGEJO_ADMIN_EMAIL=admin@agentforge.local

# Secret pour les webhooks Forgejo → Orchestrateur
# Générer avec : openssl rand -hex 32
FORGEJO_WEBHOOK_SECRET=change_this_webhook_secret

# Nom du repo de travail des agents (créé automatiquement par install.sh)
FORGEJO_WORKSPACE_REPO=agentforge-workspace

# Token API Forgejo (généré automatiquement par install.sh — ne pas renseigner)
FORGEJO_API_TOKEN=

# -----------------------------------------------------------------------------
# Orchestrateur Python
# -----------------------------------------------------------------------------
ORCHESTRATOR_PORT=8000

# Chemin local où les workspaces des tâches sont montés
WORKSPACES_DIR=/tmp/agentforge-workspaces

# Timeout max pour une tâche agent (en secondes)
TASK_TIMEOUT_SECONDS=1800

# Ressources Kata Container par tâche
KATA_VCPUS=2
KATA_RAM_MB=2048
KATA_DISK_GB=10

# -----------------------------------------------------------------------------
# LangFuse — Tracing self-hosted
# -----------------------------------------------------------------------------
LANGFUSE_PORT=3010

# Générer avec : openssl rand -base64 32
LANGFUSE_SECRET_KEY=change_this_langfuse_secret_key

# Générer avec : openssl rand -base64 32
LANGFUSE_SALT=change_this_langfuse_salt

# Clés API LangFuse projet (générées par install.sh — ne pas renseigner manuellement)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY_API=

# -----------------------------------------------------------------------------
# PostgreSQL — Base de données Forgejo
# -----------------------------------------------------------------------------
POSTGRES_FORGEJO_DB=forgejo
POSTGRES_FORGEJO_USER=forgejo
POSTGRES_FORGEJO_PASS=forgejo_db_password_here

# -----------------------------------------------------------------------------
# PostgreSQL — Base de données LangFuse
# -----------------------------------------------------------------------------
POSTGRES_LANGFUSE_DB=langfuse
POSTGRES_LANGFUSE_USER=langfuse
POSTGRES_LANGFUSE_PASS=langfuse_db_password_here

# -----------------------------------------------------------------------------
# Proxy sidecar (injection API keys)
# -----------------------------------------------------------------------------
PROXY_PORT=8877

# Whitelist des domaines autorisés depuis les agents (séparés par virgule)
PROXY_ALLOWED_HOSTS=api.anthropic.com,api.openai.com

# -----------------------------------------------------------------------------
# Docker / réseau interne
# -----------------------------------------------------------------------------
# Nom du réseau Docker interne
DOCKER_NETWORK=agentforge_net

# Préfixe des noms de containers
COMPOSE_PROJECT_NAME=agentforge
